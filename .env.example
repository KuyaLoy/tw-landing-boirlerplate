# ----------------------------------------------
# .env.example — copy to .env and fill in real values
# ----------------------------------------------
# .env is gitignored. Never commit real secrets.
# Both keys come from https://www.google.com/recaptcha/admin
# Use v3 keys — this boilerplate calls grecaptcha.execute() with a score check.

# Public site key (safe to expose in HTML/JS)
RECAPTCHA_SITE_KEY=

# Server secret (NEVER expose to client)
RECAPTCHA_SECRET_KEY=

# ----------------------------------------------
# Form recipients
# ----------------------------------------------
# FORM_ADMIN_EMAIL is the primary "To:" — required for form submissions.
# CC and BCC are optional. All three accept comma-separated lists,
# e.g. FORM_BCC_EMAIL="a@x.com, b@x.com"

FORM_ADMIN_EMAIL=
FORM_CC_EMAIL=
FORM_BCC_EMAIL=

# ----------------------------------------------
# Trusted hosts (Host header injection guard)
# ----------------------------------------------
# Comma-separated list of hostnames that are allowed to serve this site.
# Anything else gets rejected with HTTP 400 in production.
#
# Wildcards: *.example.com matches any single-or-multi-level subdomain.
# Examples:
#   ALLOWED_HOSTS=angel.com, www.angel.com, *.angel.com
#   ALLOWED_HOSTS=mybrand.com.au, *.mybrand.com.au
#
# Leave blank for local development — localhost / .test / .local / 192.168.*
# are always trusted automatically.
ALLOWED_HOSTS=

# ----------------------------------------------
# SMTP (optional) — auto-detected
# ----------------------------------------------
# Default behaviour: form.php uses PHP's built-in mail() function. Works on
# 95% of shared hosts that have a properly-configured local MTA + auto-DKIM.
#
# To upgrade to authenticated SMTP (better deliverability, fixes the "via" /
# spam folder warnings), fill in SMTP_HOST below. If it's filled, form.php
# automatically uses PHPMailer + SMTP. If it's blank, mail() is used.
#
# Recommended providers (all give you DKIM + SPF + DMARC alignment once you
# verify your sending domain in their panel):
#   - Resend       https://resend.com         (free 100/day, modern API)
#   - MailerSend   https://mailersend.com     (free 3,000/month)
#   - Brevo        https://brevo.com          (free 300/day)
#   - Amazon SES   https://aws.amazon.com/ses (~$0.10 per 1,000 emails)

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls
SMTP_FROM_NAME=
