    "archiver": "^7.0.1",
    "browser-sync": "^3.0.4",
    "chokidar": "^3.6.0",
    "cssnano": "^7.0.6",
    "esbuild": "^0.27.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0"
  }
